# Copie para .env e preencha. Carregue com: export $(cat .env | xargs)  (ou python-dotenv)

# ---- Geração ----
SONA_PROVIDER=replicate
REPLICATE_API_TOKEN=            # obrigatório para gerar (https://replicate.com/account)
SONA_REPLICATE_MODEL=zsxkib/instant-id:2e4785a4d80dadf580077b2244c8d7c05d8e3faac04a04c02d8e099dd2876789
SONA_STYLE_LORA=               # opcional: URL/identificador de uma LoRA de estilo The Sims 3

# alternativa self-hosted:
# SONA_PROVIDER=comfyui
# SONA_COMFYUI_URL=http://localhost:8188

# ---- Dispositivo dos modelos de CV ----
SONA_DEVICE=cpu                # ou cuda

# ---- Limiares (opcionais; defaults sensatos no config.py) ----
SONA_DET_SCORE_MIN=0.55
SONA_FACE_MIN_RATIO=0.10
SONA_REALNESS_MIN=0.65
SONA_REALNESS_ENABLED=1
SONA_MULTIFACE_AMBIGUOUS_RATIO=0.80
SONA_SIMILARITY_MIN=0.45
SONA_MAX_RETRIES=2
SONA_MAX_SIDE_PX=1280
SONA_MAX_UPLOAD_MB=15
