# Copie para .env e preencha. O app carrega o .env automaticamente (python-dotenv).

# ---- Geracao ----
# Providers:
#   flux_pulid        -> Flux + PuLID (identidade + estilo por prompt). Funciona ja. [padrao]
#   comfyui_replicate -> Flux + PuLID + LoRA Sims via ComfyUI na nuvem (maxima fidelidade)
#   replicate         -> SDXL InstantID (fallback)
#   comfyui           -> ComfyUI self-hosted (GPU propria)
SONA_PROVIDER=flux_pulid
REPLICATE_API_TOKEN=            # obrigatorio (https://replicate.com/account)

# LoRA de estilo The Sims (Flux). Usada pelo provider comfyui_replicate.
SONA_STYLE_LORA=dvyio/flux-lora-the-sims

SONA_FLUX_PULID_MODEL=bytedance/flux-pulid
SONA_COMFYUI_REPLICATE_MODEL=fofr/any-comfyui-workflow
# SONA_COMFYUI_WORKFLOW_PATH=         # opcional: caminho do seu workflow (API format)
# SONA_REPLICATE_MODEL=zsxkib/instant-id:2e4785a4d80dadf580077b2244c8d7c05d8e3faac04a04c02d8e099dd2876789
# SONA_COMFYUI_URL=http://localhost:8188

# ---- Dispositivo dos modelos de CV ----
SONA_DEVICE=cpu                # ou cuda

# ---- Limiares (opcionais) ----
SONA_DET_SCORE_MIN=0.55
SONA_FACE_MIN_RATIO=0.10
SONA_REALNESS_MIN=0.65
SONA_REALNESS_ENABLED=1
SONA_MULTIFACE_AMBIGUOUS_RATIO=0.80
SONA_SIMILARITY_MIN=0.45
SONA_MAX_RETRIES=2
SONA_MAX_SIDE_PX=1280
SONA_MAX_UPLOAD_MB=15
